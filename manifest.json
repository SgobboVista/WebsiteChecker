{
  "manifest_version": 3,
  "name": "SGOVI Website Checker",
  "version": "31.2",
  "permissions": [
    "storage", 
    "activeTab"
  ],
  "host_permissions": [
    "https://sgobbovista.de/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/*", 
        "*://*.google.de/*",
        "*://*.bing.com/*"
      ],
      "js": ["lang.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}